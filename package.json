{
  "name": "freegeographyapp",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @geography/web dev",
    "build": "pnpm --filter @geography/web build",
    "preview": "pnpm --filter @geography/web preview",
    "typecheck": "pnpm --filter @geography/web exec tsc -b",
    "test": "pnpm --filter @geography/web exec tsc -b"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeappstore-online/geography.git"
  }
}
